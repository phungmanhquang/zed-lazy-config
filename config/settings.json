// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
    "enabled": true
  },
  "use_system_window_tabs": false,
  "centered_layout": {
    "left_padding": 0.2
  },
  "bottom_dock_layout": "contained",
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": false
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show_tab_bar_buttons": true,
    "show": true
  },
  "title_bar": {
    "show_user_picture": true,
    "show_menus": false,
    "show_branch_icon": true
  },
  "terminal": {
    "button": true
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true
  },
  "project_panel": {
    "button": true,
    "hide_root": true,
    "auto_fold_dirs": false,
    "sticky_scroll": true,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "indent_guides": {
      // "show": "never",
    }
  },
  "file_finder": {
    "modal_max_width": "small"
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true
  },
  "show_edit_predictions": false,
  "git_panel": {
    "sort_by_path": true,
    "tree_view": false
  },
  "show_whitespaces": "none",
  "indent_guides": {
    "active_line_width": 2,
    "background_coloring": null,
    "enabled": false,
    "line_width": null
  },
  "auto_update": false,
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
      "enable_thinking": false
    },
    "favorite_models": [],
    "single_file_review": true,
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "vim_mode": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Tokyo Night",
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 8,
      "min_column": 0,
      "max_severity": null
    },
    "cargo": null
  }
}
